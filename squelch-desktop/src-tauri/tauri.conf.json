{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "squelch",
  "version": "0.1.0",
  "identifier": "ai.braelyn.squelch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "squelch",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "theme": "Dark",
        "backgroundColor": "#0b0d0e"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* https://*.ts.net https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
